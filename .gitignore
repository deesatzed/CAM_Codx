# --- Project-local working artifacts ---
# Baselines collected during Phase 1 — these contain real session transcripts
# and per-machine measurements; they are reproduced per environment, not shared.
# We exclude the *contents* of baselines/ rather than the directory itself,
# so the schema template + repo selection file can be re-included with negative patterns.
baselines/*
# Re-include the committed schema/selection files:
!baselines/manifest.json.template
!baselines/repo_set.txt
!baselines/manifest.json
# Re-include the RSS baseline measurements — authoritative for lightness claim:
!baselines/legacy_mcp_rss.txt
!baselines/new_mcp_rss.txt
# Re-include failure corpus — 20 real failures from git history, required for Phase 1.5 / 9.5:
!baselines/failures/
!baselines/failures/**

# Coverage-gap notes and decision log are project-local; commit only when stabilized.
docs/_coverage_gaps.md
docs/_decision_log.md
docs/_design_approval.md

# Local SQLite databases — never committed.
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Test fixtures are real but small — tracked as binary artifacts.
!tests/fixtures/claw_slice.db

# Local logs
*.log
logs/
